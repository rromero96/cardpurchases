    {
      "name": "SETUP - CRUD Básico",
      "item": [
        {
          "name": "1. Create Bank (Setup)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/banks?name=Banco Test&cuit=20123456789&address=Av. Test&telephone=1123456789&direction=Centro",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "banks"],
              "query": [
                {"key": "name", "value": "Banco Test"},
                {"key": "cuit", "value": "20123456789"},
                {"key": "address", "value": "Av. Test"},
                {"key": "telephone", "value": "1123456789"},
                {"key": "direction", "value": "Centro"}
              ]
            }
          }
        },
        {
          "name": "2. Create CardHolder (Setup)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cardholders?completeName=Juan Perez&dni=12345678&cuil=20123456789&address=Calle 1&telephone=1123456789&entryDate=2020-01-15",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "cardholders"],
              "query": [
                {"key": "completeName", "value": "Juan Perez"},
                {"key": "dni", "value": "12345678"},
                {"key": "cuil", "value": "20123456789"},
                {"key": "address", "value": "Calle 1"},
                {"key": "telephone", "value": "1123456789"},
                {"key": "entryDate", "value": "2020-01-15"}
              ]
            }
          }
        },
        {
          "name": "3. Create Card (Setup)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/cards?cardHolderId=1&bankId=1&number=4111111111111111&ccv=789&cardholderNameInCard=JUAN PEREZ&since=2023-01-01&expirationDate=2028-12-31",
