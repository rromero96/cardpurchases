{
  "info": {
    "name": "Card Purchases - 11 Casos de Uso",
    "description": "API REST para gestión de pagos con tarjetas - MongoDB Version\n\n✅ FASE 2: Migración a MongoDB completada (2 Marzo 2026)\n\n11 CASOS DE USO REQUERIDOS + SETUP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "bankId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cardHolderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cardId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "SETUP - Crear datos base",
      "item": [
        {
          "name": "1. Create Bank (Setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var jsonData = pm.response.json();", "pm.collectionVariables.set('bankId', jsonData.id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/banks?name=Banco Test&cuit=20123456789&address=Av. Test&telephone=1123456789&direction=Centro",
              "host": ["{{baseUrl}}"],
              "path": ["banks"],
              "query": [
                {"key": "name", "value": "Banco Test"},
                {"key": "cuit", "value": "20123456789"},
                {"key": "address", "value": "Av. Test"},
                {"key": "telephone", "value": "1123456789"},
                {"key": "direction", "value": "Centro"}
              ]
            }
          }
        },
        {
          "name": "2. Create CardHolder (Setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var jsonData = pm.response.json();", "pm.collectionVariables.set('cardHolderId', jsonData.id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cardholders?completeName=Juan Perez&dni=12345678&cuil=20123456789&address=Calle 1&telephone=1123456789&entryDate=2020-01-15",
              "host": ["{{baseUrl}}"],
              "path": ["cardholders"],
              "query": [
                {"key": "completeName", "value": "Juan Perez"},
                {"key": "dni", "value": "12345678"},
                {"key": "cuil", "value": "20123456789"},
                {"key": "address", "value": "Calle 1"},
                {"key": "telephone", "value": "1123456789"},
                {"key": "entryDate", "value": "2020-01-15"}
              ]
            }
          }
        },
        {
          "name": "3. Create Card (Setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var jsonData = pm.response.json();", "pm.collectionVariables.set('cardId', jsonData.id);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards?cardHolderId={{cardHolderId}}&bankId={{bankId}}&number=4111111111111111&ccv=789&cardholderNameInCard=JUAN PEREZ&since=2023-01-01&expirationDate=2028-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["cards"],
              "query": [
                {"key": "cardHolderId", "value": "{{cardHolderId}}"},
                {"key": "bankId", "value": "{{bankId}}"},
                {"key": "number", "value": "4111111111111111"},
                {"key": "ccv", "value": "789"},
                {"key": "cardholderNameInCard", "value": "JUAN PEREZ"},
                {"key": "since", "value": "2023-01-01"},
                {"key": "expirationDate", "value": "2028-12-31"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "CASO 1: Agregar promoción de descuento",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/promotions/discount?bankId={{bankId}}&code=DESC2026&promotionTitle=Descuento Anual 15%&nameStore=SuperMercado&cuitStore=20999888777&validityStartDate=2026-01-01&validityEndDate=2026-12-31&discountPercentage=15&priceCap=5000&onlyCash=false",
          "host": ["{{baseUrl}}"],
          "path": ["promotions", "discount"],
          "query": [
            {"key": "bankId", "value": "{{bankId}}"},
            {"key": "code", "value": "DESC2026"},
            {"key": "promotionTitle", "value": "Descuento Anual 15%"},
            {"key": "nameStore", "value": "SuperMercado"},
            {"key": "cuitStore", "value": "20999888777"},
            {"key": "validityStartDate", "value": "2026-01-01"},
            {"key": "validityEndDate", "value": "2026-12-31"},
            {"key": "discountPercentage", "value": "15"},
            {"key": "priceCap", "value": "5000"},
            {"key": "onlyCash", "value": "false"}
          ]
        }
      }
    },
    {
      "name": "CASO 2: Editar fechas de pago",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/purchases/monthly?cardId={{cardId}}&store=TiendaQuotas&cuitStore=20999888777&amount=2000&numberOfQuotas=3&interest=8.0&paymentVoucher=VOUCHER003",
          "host": ["{{baseUrl}}"],
          "path": ["purchases", "monthly"],
          "query": [
            {"key": "cardId", "value": "{{cardId}}"},
            {"key": "store", "value": "TiendaQuotas"},
            {"key": "cuitStore", "value": "20999888777"},
            {"key": "amount", "value": "2000"},
            {"key": "numberOfQuotas", "value": "3"},
            {"key": "interest", "value": "8.0"},
            {"key": "paymentVoucher", "value": "VOUCHER003"}
          ]
        }
      }
    },
    {
      "name": "CASO 3: Generar total de pago del mes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/payments/month/2026/02",
          "host": ["{{baseUrl}}"],
          "path": ["payments", "month", "2026", "02"]
        }
      }
    },
    {
      "name": "CASO 4: Obtener tarjetas >5 años",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cards/old",
          "host": ["{{baseUrl}}"],
          "path": ["cards", "old"]
        }
      }
    },
    {
      "name": "CASO 5: Obtener información de compra",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/purchases/monthly?cardId={{cardId}}&store=ElectrodomésticosTienda&cuitStore=20999888777&amount=15000&numberOfQuotas=12&interest=12.5&paymentVoucher=VOUCHER004",
          "host": ["{{baseUrl}}"],
          "path": ["purchases", "monthly"],
          "query": [
            {"key": "cardId", "value": "{{cardId}}"},
            {"key": "store", "value": "ElectrodomésticosTienda"},
            {"key": "cuitStore", "value": "20999888777"},
            {"key": "amount", "value": "15000"},
            {"key": "numberOfQuotas", "value": "12"},
            {"key": "interest", "value": "12.5"},
            {"key": "paymentVoucher", "value": "VOUCHER004"}
          ]
        }
      }
    },
    {
      "name": "CASO 6: Eliminar promoción por código",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/promotions/DESC2026",
          "host": ["{{baseUrl}}"],
          "path": ["promotions", "DESC2026"]
        }
      }
    },
    {
      "name": "CASO 7: Obtener promociones disponibles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/promotions/available?cuitStore=20999888777&startDate=2025-01-01&endDate=2026-12-31",
          "host": ["{{baseUrl}}"],
          "path": ["promotions", "available"],
          "query": [
            {"key": "cuitStore", "value": "20999888777"},
            {"key": "startDate", "value": "2025-01-01"},
            {"key": "endDate", "value": "2026-12-31"}
          ]
        }
      }
    },
    {
      "name": "CASO 8: Top 10 titulares por gasto",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cardholders/top-10-spending",
          "host": ["{{baseUrl}}"],
          "path": ["cardholders", "top-10-spending"]
        }
      }
    },
    {
      "name": "CASO 9: Local con más compras",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/purchases/store-most-purchases",
          "host": ["{{baseUrl}}"],
          "path": ["purchases", "store-most-purchases"]
        }
      }
    },
    {
      "name": "CASO 10: Banco con más compras",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/banks/most-purchases",
          "host": ["{{baseUrl}}"],
          "path": ["banks", "most-purchases"]
        }
      }
    },
    {
      "name": "CASO 11: Cantidad de clientes por banco",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/banks/client-count",
          "host": ["{{baseUrl}}"],
          "path": ["banks", "client-count"]
        }
      }
    }
  ]
}
